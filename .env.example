# 数据库在服务器；局域网内可直接连 192.168.1.14（需服务器执行 deploy/enable-lan-access.sh）
# 若未开放局域网库端口，本机开发用: .\scripts\db-tunnel.ps1 并改为 127.0.0.1
DATABASE_URL="postgresql://community:community@192.168.1.14:5432/community?schema=public"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
