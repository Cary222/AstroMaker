#!/usr/bin/env bash
# 安装到 ~/work/company/community.git/hooks/post-receive
set -euo pipefail

WORK_TREE="$HOME/work/company/community"
LOG="$WORK_TREE/deploy.log"

exec >>"$LOG" 2>&1
echo "===== deploy $(date -Iseconds) ====="

while read -r _ newrev refname; do
  if [[ "$refname" != "refs/heads/main" ]]; then
    echo "skip non-main: $refname"
    continue
  fi

  cd "$WORK_TREE"
  unset GIT_DIR GIT_WORK_TREE
  git pull origin main

  if [[ -f package-lock.json ]]; then
    npm ci
  else
    npm install
  fi

  npx prisma generate
  npx prisma migrate deploy
  npm run build

  if [[ -f deploy/fix-crlf.py ]]; then
    python3 deploy/fix-crlf.py || true
  fi

  if [[ -x deploy/install-services.sh ]]; then
    bash deploy/install-services.sh
  else
    systemctl --user restart community.service
    systemctl --user try-restart community-proxy.service 2>/dev/null || true
  fi

  # shellcheck disable=SC1091
  [[ -f deploy/ports.env ]] && source deploy/ports.env
  PROD_PORT="${PROD_PORT:-3000}"
  EXTERNAL_PORT="${EXTERNAL_PORT:-8080}"

  sleep 2
  systemctl --user is-active --quiet community.service
  curl -sf "http://127.0.0.1:${PROD_PORT}/" >/dev/null
  if systemctl --user is-active --quiet community-proxy.service 2>/dev/null; then
    curl -sf "http://127.0.0.1:${EXTERNAL_PORT}/" >/dev/null
  fi

  echo "deploy ok: $newrev (prod :${PROD_PORT}, external :${EXTERNAL_PORT})"
done
